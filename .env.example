# ── Required ──────────────────────────────────────────────────────────────────
# Twitch application credentials (https://dev.twitch.tv/console/apps)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Bot account OAuth tokens
TWITCH_ACCESS_TOKEN=
TWITCH_REFRESH_TOKEN=

# ── Optional: bot identity ────────────────────────────────────────────────────
# Twitch login name of the bot account (default: worxbend)
TWITCH_BOT_USERNAME=worxbend

# ── Optional: server ──────────────────────────────────────────────────────────
VIZER_SERVER_HOST=0.0.0.0
VIZER_SERVER_PORT=8080

# ── Optional: logging ─────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
VIZER_LOG_LEVEL=INFO
